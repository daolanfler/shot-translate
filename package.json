{
  "name": "shot-translate",
  "version": "0.1.0",
  "description": "Windows screenshot translation desktop app built with Electron, React, and local OCR.",
  "main": "out/main/index.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -b",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder"
  },
  "build": {
    "appId": "com.codex.shottranslate",
    "productName": "Shot Translate",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tesseract.js": "^6.0.1",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
