{
  "name": "shot-translate",
  "version": "0.1.0",
  "description": "Windows screenshot translation desktop app built with Electron, React, and local OCR.",
  "main": "out/main/index.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "ocr:bench": "electron scripts/ocr-benchmark.cjs",
    "ocr:bench:real": "electron scripts/ocr-benchmark.cjs --run-ocr",
    "smoke:capture": "node scripts/smoke-capture.cjs"
  },
  "build": {
    "appId": "com.codex.shottranslate",
    "productName": "Shot Translate",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "generic",
      "url": "https://github.com/daolanfler/shot-translate/releases/latest/download/"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-windows-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@mantine/core": "^9.2.1",
    "@mantine/hooks": "^9.2.1",
    "@tabler/icons-react": "^3.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^6.0.1",
    "tw-animate-css": "^1.4.0",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.6.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-builder",
      "esbuild"
    ]
  }
}
